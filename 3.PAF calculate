# ============================================================
# PAF estimation (Monte Carlo) + weighted aggregation (PCA-based)
# This script is de-identified: all column names should be anonymized
# before running (e.g., a, b, c ...).
# ============================================================

suppressPackageStartupMessages({
  library(survival)
  library(MASS)
  library(dplyr)
  library(purrr)
  library(tibble)
  library(psych)
  library(data.table)
})

# ------------------------------------------------------------
# Utility: anonymize column names locally (DO NOT COMMIT mapping)
# ------------------------------------------------------------
anonymize_columns <- function(df, prefix = "v", digits = 3) {
  stopifnot(is.data.frame(df))
  old_names <- names(df)
  new_names <- sprintf(paste0(prefix, "%0", digits, "d"), seq_along(old_names))
  names(df) <- new_names
  mapping <- tibble(old = old_names, new = new_names)
  list(data = df, mapping = mapping)
}

# ------------------------------------------------------------
# Main function: Monte Carlo PAF with uncertainty interval
# ------------------------------------------------------------
calculate_paf_mc <- function(df, time_col, event_col, exposure_col, covar_cols,
                             exposed_level = "High_risk",
                             coef_suffix = "High_risk",
                             n_sim = 1000, ci_level = 0.95, seed = 123) {

  # Build Cox model formula
  fml <- as.formula(
    paste0("Surv(", time_col, ",", event_col, ") ~ ",
           exposure_col, " + ", paste(covar_cols, collapse = " + "))
  )

  fit <- coxph(fml, data = df)

  # Identify coefficient name for the exposure contrast
  coef_name <- paste0(exposure_col, coef_suffix)

  if (!coef_name %in% names(coef(fit))) {
    warning(paste("Coefficient not found:", coef_name))
    return(tibble(
      exposure = exposure_col,
      paf = NA_real_,
      ci_lower = NA_real_,
      ci_upper = NA_real_,
      model = "model_1",
      hr = NA_real_,
      n_sim = n_sim
    ))
  }

  beta_hat <- coef(fit)[coef_name]
  vcov_mat <- vcov(fit)

  set.seed(seed)
  sim_coef <- MASS::mvrnorm(n = n_sim, mu = coef(fit), Sigma = vcov_mat)

  sim_beta <- sim_coef[, coef_name]
  sim_hr <- exp(sim_beta)

  # Exposure prevalence
  p_exposed <- mean(df[[exposure_col]] == exposed_level, na.rm = TRUE)

  # PAF simulation
  sim_paf <- p_exposed * (sim_hr - 1) / (p_exposed * (sim_hr - 1) + 1)

  alpha <- 1 - ci_level
  paf_ci <- quantile(sim_paf, probs = c(alpha / 2, 1 - alpha / 2), na.rm = TRUE)

  hr_original <- exp(beta_hat)
  paf_original <- p_exposed * (hr_original - 1) / (p_exposed * (hr_original - 1) + 1)

  tibble(
    exposure = exposure_col,
    paf = paf_original,
    ci_lower = as.numeric(paf_ci[1]),
    ci_upper = as.numeric(paf_ci[2]),
    model = "model_1",
    hr = as.numeric(hr_original),
    n_sim = n_sim
  )
}

# ------------------------------------------------------------
# Example workflow (expects de-identified columns)
# ------------------------------------------------------------

# df_main: analysis dataset (already de-identified)
# time_col: survival time column name (de-identified)
# event_col: event indicator column name (de-identified)
# covar_cols: covariate column names (de-identified)
# exposure_cols: exposure variable names used in model_1 (de-identified)

run_paf_pipeline <- function(df_main,
                             time_col,
                             event_col,
                             covar_cols,
                             exposure_cols,
                             n_sim = 1000,
                             out_csv = "paf_results.csv") {

  # Unweighted PAF for each exposure
  paf_tbl <- purrr::map_dfr(exposure_cols, function(x) {
    calculate_paf_mc(
      df = df_main,
      time_col = time_col,
      event_col = event_col,
      exposure_col = x,
      covar_cols = covar_cols,
      n_sim = n_sim
    )
  })

  # Weighted aggregation using tetrachoric PCA communality
  pca_df <- df_main %>%
    dplyr::select(all_of(exposure_cols)) %>%
    na.omit() %>%
    mutate(across(everything(), ~ as.numeric(.x) - 1))

  tetra_cor <- psych::tetrachoric(pca_df, na.rm = TRUE)
  cor_matrix <- tetra_cor$rho

  ev <- eigen(cor_matrix)
  eigenvalues <- ev$values
  eigenvectors <- ev$vectors

  n_components <- sum(eigenvalues > 1)
  if (n_components < 1) {
    stop("No PCA components retained under eigenvalue > 1 rule.")
  }

  retained <- eigenvectors[, 1:n_components, drop = FALSE]
  communality <- rowSums(retained^2)

  communality_df <- tibble(
    exposure = colnames(pca_df),
    communality = communality
  )

  paf_tbl <- paf_tbl %>%
    left_join(communality_df, by = "exposure")

  # Overall weighted PAF
  overall_weighted_paf <- 1 - prod(1 - (1 - paf_tbl$communality) * paf_tbl$paf)

  # Individual weighted PAF allocation
  paf_tbl <- paf_tbl %>%
    mutate(
      overall_weighted_paf = overall_weighted_paf,
      weighted_paf = (paf / sum(paf, na.rm = TRUE)) * overall_weighted_paf
    )

  data.table::fwrite(paf_tbl, out_csv)
  paf_tbl
}
